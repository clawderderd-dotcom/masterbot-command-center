# MasterBot Command Center (MCC)

# Server bind (local-only by default)
MCC_HOST=127.0.0.1
MCC_PORT=8787

# Persistence
# MCC_DATA_DIR=/home/openclaw/clawd/masterbot-command-center/packages/server/data
# MCC_DB_PATH=/home/openclaw/clawd/masterbot-command-center/packages/server/data/mcc.sqlite3
# MCC_BACKUP_DIR=/home/openclaw/clawd/masterbot-command-center/packages/server/backups

# Gateway connection
# IMPORTANT: Do not commit secrets. Do not paste secrets into chat.
MCC_GATEWAY_URL=ws://127.0.0.1:18789/ws
# MCC_GATEWAY_TOKEN=...
# MCC_GATEWAY_PASSWORD=...
